OPENAI_API_KEY=
MODEL=gpt-4o-mini
LOCAL_LLM_ENABLED=false
LOCAL_LLM_MODEL=tinyllama
LOCAL_LLM_URL=http://ollama:11434/api/generate
HF_TOKEN=

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=4
WHISPER_BEAM_SIZE=1
WHISPER_VAD_FILTER=true

PIPER_MODEL_PATH=/models/piper/ru_RU-irina-medium.onnx
PIPER_SAMPLE_RATE=22050
PIPER_AUDIO_FORMAT=S16_LE
PIPER_PROCESS_TIMEOUT=30

SKILLS_ENABLED=true
ENABLED_SKILLS=help

AUDIO_DEVICE_ID=1
AUDIO_INPUT_SR=48000
AUDIO_TARGET_SR=16000
AUDIO_CHANNELS=1
AUDIO_RECORD_DURATION=6
